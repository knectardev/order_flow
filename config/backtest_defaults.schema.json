{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local/orderflow/backtest_defaults.schema.json",
  "title": "Order flow simulated broker defaults",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "$schema": { "type": "string" },
    "version": { "type": "integer", "minimum": 1 },
    "_doc": { "type": "string" },
    "_comment": { "type": "string" },
    "initial_capital": { "type": "number" },
    "qty": { "type": "integer", "minimum": 1 },
    "slippage_ticks": { "type": "number" },
    "commission_per_side": { "type": "number", "minimum": 0 },
    "tick_size": { "type": "number", "exclusiveMinimum": 0 },
    "point_value": { "type": "number", "exclusiveMinimum": 0 },
    "stop_loss_ticks": { "type": ["number", "null"] },
    "take_profit_ticks": { "type": ["number", "null"] },
    "ignore_same_side_fire_when_open": { "type": "boolean" },
    "flip_on_opposite_fire": { "type": "boolean" },
    "exit_on_stop_loss": { "type": "boolean" },
    "exit_on_take_profit": { "type": "boolean" },
    "close_at_end_of_window": { "type": "boolean" },
    "entry_next_bar_open": { "type": "boolean" },
    "entry_gap_guard_max_ticks": { "type": ["number", "null"], "minimum": 0 }
  },
  "required": ["version"]
}
